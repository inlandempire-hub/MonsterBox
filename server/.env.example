# Copy to .env and fill in. Never commit .env.

# --- Database ---
# Local dev: SQLite (zero setup). Production: your Supabase Postgres URL, e.g.
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=sqlite:///./monsterbox.db

# --- Supabase auth ---
# Supabase Dashboard -> Project Settings -> API -> JWT Secret
# (Only needed for legacy HS256 projects. Modern projects sign tokens with
#  asymmetric ES256 keys, verified via the project's public JWKS instead.)
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated

# Project base URL, e.g. https://<ref>.supabase.co. Optional: if left blank it
# is derived from DATABASE_URL. Used to fetch the public keys for ES256 tokens.
SUPABASE_URL=

# --- Local dev convenience ---
# When true, the API trusts an "X-Dev-User: someone@example.com" header instead
# of a real Supabase token, so you can exercise the API before wiring up auth.
# MUST be false in production.
DEV_AUTH=true

# Comma-separated list of allowed browser origins (the PWA).
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://127.0.0.1:8077
